{
  "productName": "PokeMMO Companion",
  "version": "0.1.0",
  "identifier": "com.retrogramx.pokemmo-companion",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PokeMMO Companion",
        "width": 360,
        "height": 200,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": true,
        "minWidth": 300,
        "minHeight": 150
      }
    ]
  },
  "plugins": {}
}
